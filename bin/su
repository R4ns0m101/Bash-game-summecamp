#!/bin/bash

if [ "$1" == "admin" ]; then
    read -sp "Password: " pass
    echo

    if [ "$pass" == "dungeon_root" ]; then
        echo "👑 You are now admin — spawning admin shell..."
        ROLE=admin PS1="(admin) \w \$ " exec bash
    else
        echo "❌ Authentication failed"
    fi
else
    echo "Usage: su admin"
fi
